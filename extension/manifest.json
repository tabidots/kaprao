{
    "manifest_version": 3,
    "name": "Kaprao Thai Popup Dictionary",
    "version": "1.0.0",
    "description": "Inline Thai pronunciation and gloss annotations",
    "icons": {
        "16": "img/icon-16.png",
        "48": "img/icon-48.png",
        "128": "img/icon-128.png"
    },
    "action": {
        "default_icon": {
            "16": "img/icon-16.png",
            "48": "img/icon-48.png",
            "128": "img/icon-128.png"
        },
        "default_title": "Kaprao Popup Dictionary (click to toggle)"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content/bundle.js",
                "content/handlebars.runtime-25c696b.js",
                "content/popup.precompiled.js",
                "content/shortcutHint.precompiled.js",
                "content/entryBlock.precompiled.js"
            ],
            "type": "module",
            "css": [
                "styles/kaprao.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "options_ui": {
        "page": "options.html",
        "open_in_tab": false
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "data/thai_en.json.gz",
                "styles/popup.css",
                "img/*",
                "assets/NotoSansThai-VariableFont_wdth,wght.ttf",
                "assets/Mali-Light.ttf",
                "assets/Sriracha-Regular.ttf"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "permissions": [
        "storage",
        "commands",
        "activeTab"
    ],
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Alt+K",
                "mac": "Alt+K"
            }
        },
        "speak-current": {
            "suggested_key": {
                "mac": "Alt+3",
                "default": "Alt+3"
            },
            "description": "Speak highlighted word"
        },
        "change-font": {
            "suggested_key": {
                "mac": "Alt+W",
                "default": "Alt+W"
            },
            "description": "Change font"
        }
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'; font-src 'self'"
    }
        
}